{
  "name": "finance-tracker-server",
  "type": "module",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.ts",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "test": "vitest --run",
    "test:integration": "vitest --run --config vitest.integration.config.ts",
    "test:integration:db:up": "docker compose -f compose.integration.yml up -d --wait mongo-integration",
    "test:integration:db:down": "docker compose -f compose.integration.yml down -v",
    "test:integration:full": "bash ./scripts/test-integration.sh",
    "test:quiet": "vitest --run --reporter=dot",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --reporter=dot --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "fix": "node scripts/fix.mjs",
    "coverage:missing": "node scripts/coverage-missing.mjs",
    "coverage:summary-only": "pnpm test:coverage --coverage.reporter=json-summary",
    "coverage:check-missing": "vitest --run --reporter=dot --coverage --coverage.reporter=json-summary --coverage.reporter=lcov && node scripts/coverage-missing.mjs"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "argon2": "^0.44.0",
    "csv": "^6.4.1",
    "csv-stringify": "^6.6.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.1",
    "fastify-type-provider-zod": "^6.1.0",
    "fastify-zod-openapi": "^5.5.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@faker-js/faker": "^10.1.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.9.1",
    "@vitest/coverage-v8": "^4.0.3",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.8.1",
    "supertest": "^7.1.4",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.3"
  }
}
