### LOGIN
# @name loginReq
POST http://localhost:5000/api/auth/login
Content-Type: application/json

{
  "email": "w@z.pl",
  "password": "123"
}

###

@baseUrl = http://localhost:5000/api/accounts
@accessToken = {{loginReq.response.body.accessToken}}

#--------------------------------------------------------------------------------------
#--------------------------------------------------------------------------------------

### GET ALL ACCOUNTS
GET {{baseUrl}}
Accept: application/json
Authorization: Bearer {{accessToken}}

#--------------------------------------------------------------------------------------
#--------------------------------------------------------------------------------------

### GET ACCOUNT BY ID
GET {{baseUrl}}/69b0858be7e4554a4e563505
Accept: application/json
Authorization: Bearer {{accessToken}}

#--------------------------------------------------------------------------------------
#--------------------------------------------------------------------------------------

### CREATE NEW ACCOUNT
POST {{baseUrl}}
Accept: application/json
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "   Alior Bank   "
}

#--------------------------------------------------------------------------------------
#--------------------------------------------------------------------------------------

### UPDATE ACCOUNT
PUT {{baseUrl}}/69b16e1eeb8e59fdad7a2754
Accept: application/json
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "m-BANK"
}

