{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": "./src",
    "paths": {
      "@utils/*": ["utils/*"],
      "@app/*": ["app/*"],
      "@shared/*": ["shared/*"],
      "@auth/*": ["auth/*"],
      "@user/*": ["user/*"],
      "@account/*": ["account/*"],
      "@category/*": ["category/*"],
      "@transaction/*": ["transaction/*"],
      "@payment-method/*": ["payment-method/*"],
      "@testing/*": ["testing/*"],
      "@currency/*": ["currency/*"]
    },
    "types": ["node", "vitest"]
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
